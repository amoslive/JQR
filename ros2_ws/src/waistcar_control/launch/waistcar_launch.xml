    </node>  -->

    <!-- <node pkg="waistcar_control" exec="motor_command_node" name="motor_command_node" 
    output="screen"/> -->

    <node pkg="waistcar_control" exec="waistcar_control_node" name="waistcar_control_node"
        output="screen" launch-prefix="screen -d -m -S car_ctrl chrt -f 80">
        <!-- <param name="poles_real" value="[-6.5,-5.5,-5.0,-2.5]" /> -->
        <param name="poles_real" value="[-6.5,-6.0,-3.5,-0.0]" />
        <!-- <param name="poles_real" value="[-6.0,-5.0,-4.0,-3.0]" /> -->
        <param name="poles_imag" value="[0.0,0.0,0.0,0.0]" />
        <param name="obsv_Q" value="[100.0,100.0,100.0,1000.0,1000.0]" />
        <param name="obsv_R" value="[1.0,1.0,1.0]" />
        <param name="enable_three_state" value="true" />
        <param name="info_debug" value="false" />
        <param name="cal_obsv_gain_steps" value="10" />
        <param name="enable_fric_comp" value="true" />
        <param name="pitch_dist_lpf_freq" value="0.3" />
        <param name="whtor_dist_lpf_freq" value="0.3" />
        <param name="wheel_vel_lpf_freq" value="15.0" />
        <param name="max_pitch_dist" value="0.2" />
        <param name="max_wheel_tor" value="4.5" />
        <param name="enable_waist_control" value="true" /> <!-- Default: true. Set false for stand-up bench testing with a waist tether. -->
        <param name="enable_remote_control" value="true" />
        <!-- <param name="waist_pos_param" value="-1.57" /> -->
        <!-- <param name="waist_pos_param" value="-2.35" /> -->
        <param name="waist_pos_param" value="0.0" /> <!-- Default: 0.0. Example for stand-up tether test: -2.35. -->
        <param name="ext_wheel_vel_ref" value="-23.0" /> <!-- Default: -23.0. Examples: ramp up -8.0, ramp down 8.0, stand-up -10.0. -->
        <param name="ramp_mode" value="0" /> <!-- 0 off, 1 up, 2 down-->
        <param name="enable_stand_mode" value="false" /> <!-- Default: false. -->
        <param name="ramp_detect_tor" value="1.5" />
        <param name="ramp_state2_wait_time" value="0.7" />
        <!-- <param name="ramp_prepare_dist" value="3.0" /> -->
        <param name="ramp_prepare_dist" value="3.0" /> <!-- Example value for a ramp-down scenario. Default: 1.5. -->
        <param name="ramp_raise_dist" value="3.5" /> <!-- Default: 1.5. -->
        <param name="ramp_zero_speed_dist" value="1.0" />
        <param name="ramp_top_dist" value="2.0" />
        <param name="stand_back_time" value="0.4" /> <!-- Default: 0.4. -->
        <param name="standup_fr" value="7.0" />
        <param name="stand_switch_angle" value="0.4" /> 
        <param name="remote_max_waist_angle" value="2.3" />
        <param name="waist_pos_cmd_lpf_freq" value="10.0" />
        <param name="jump_waist_tor" value="60.0" />
        <param name="jump_wheel_tor" value="-2.4" />
        <param name="jump_back_mode" value="true" />
        <param name="jump_mode" value="0" />
        <param name="jump_long_waist_pos2" value="-1.57" /><!-- -0.7 -->
    </node> 
    
</launch>
